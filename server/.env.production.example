# ========================================
#  健康生活助手 - 生产环境配置模板
# ========================================
#  使用步骤:
#    1) cp .env.production.example .env.production
#    2) 修改下面所有占位符（API_KEY / LLM_API_KEY）
#    3) bash deploy.sh
#
#  注意: .env.production 已在 .gitignore 中，不会被提交
# ========================================

# ===== Server =====
PORT=3000
NODE_ENV=production

# ===== Auth =====
# 与 cloud/functions/{aiChat,aiRecommend,aiAnalysis}/index.js
# 的 BACKEND_KEY 环境变量保持完全一致
# 生成方式: openssl rand -hex 32
API_KEY=

# ===== LLM Provider =====
# openai-compatible (OpenAI / DeepSeek / 通义千问 / 智谱 / 豆包 / Ollama 等)
# mock (本地模拟，用于测试)
LLM_PROVIDER=openai-compatible

# OpenAI 兼容接口地址
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=
LLM_MODEL=deepseek-chat

# 请求超时（毫秒）
LLM_TIMEOUT_MS=30000
# 温度参数（0-1，越低越稳定）
LLM_TEMPERATURE=0.4

# ===== Data Store =====
# 容器内固定为 /app/data，配合 docker-compose volume 持久化
DATA_DIR=./data
