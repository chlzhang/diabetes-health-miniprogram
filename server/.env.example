# ===== Server =====
PORT=3000
NODE_ENV=development

# ===== Auth =====
# Mini program → cloud function → backend 共享的 API Key
API_KEY=replace-me-with-a-random-secret

# ===== LLM Provider =====
# 选择 provider: openai-compatible (通用 OpenAI 格式) | mock (本地模拟)
LLM_PROVIDER=openai-compatible

# OpenAI 兼容接口（适用于 OpenAI / DeepSeek / 通义千问 / 豆包 / 智谱 / Ollama 等）
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=sk-xxx-your-llm-api-key
LLM_MODEL=deepseek-chat
# 可选：自定义请求超时（毫秒）
LLM_TIMEOUT_MS=30000
# 可选：温度参数，越低越稳定
LLM_TEMPERATURE=0.4

# ===== Data Store =====
# 数据存储根目录
DATA_DIR=./data
