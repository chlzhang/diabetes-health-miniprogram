.hint-text { font-size: 22rpx; color: #999; margin-bottom: 16rpx; display: block; }
.preference-list { margin-top: 8rpx; }
.pref-item { display: flex; align-items: center; padding: 24rpx; border: 2rpx solid #e5e7eb; border-radius: 12rpx; margin-bottom: 12rpx; }
.pref-item.on { border-color: #0d9488; background: #f0fdfa; }
.pref-info { flex: 1; }
.pref-name { font-size: 28rpx; font-weight: 500; color: #1a1a1a; display: block; }
.pref-desc { font-size: 22rpx; color: #666; display: block; margin-top: 4rpx; }
.pref-check { width: 40rpx; height: 40rpx; border-radius: 50%; border: 2rpx solid #e5e7eb; display: flex; align-items: center; justify-content: center; font-size: 28rpx; color: transparent; }
.pref-item.on .pref-check { background: #0d9488; border-color: #0d9488; color: #fff; font-weight: 700; }
.bottom-hint { text-align: center; font-size: 22rpx; color: #999; margin-top: 16rpx; }

@media (min-width: 768px) {
  .container { max-width: 720rpx; margin: 0 auto; padding: 32rpx 24rpx; }
}
