.time-tabs { display: flex; justify-content: space-between; }
.time-tab { display: flex; flex-direction: column; align-items: center; padding: 20rpx 32rpx; border-radius: 12rpx; background: #f5f5f5; flex: 1; margin: 0 6rpx; }
.time-tab.active { background: #0d9488; color: #fff; }
.tab-icon { font-size: 36rpx; margin-bottom: 4rpx; }
.tab-name { font-size: 24rpx; }
.form-group { margin-bottom: 24rpx; }
.input-row { display: flex; align-items: center; }
.sugar-input { flex: 1; border: 2rpx solid #e5e7eb; border-radius: 12rpx; padding: 20rpx 24rpx; font-size: 36rpx; font-weight: 600; }
.unit-label { font-size: 26rpx; color: #999; margin-left: 16rpx; }
.result-card { border-left: 6rpx solid #0d9488; }
.result-header { display: flex; align-items: baseline; gap: 8rpx; margin-bottom: 16rpx; }
.result-value { font-size: 56rpx; font-weight: 700; color: #1a1a1a; }
.result-unit { font-size: 24rpx; color: #999; }
.result-std { margin-bottom: 12rpx; }
.std-label { font-size: 24rpx; color: #999; }
.std-value { font-size: 24rpx; color: #333; font-weight: 500; }
.result-suggestion { display: flex; align-items: flex-start; gap: 8rpx; background: #f0fdfa; padding: 16rpx; border-radius: 12rpx; }
.suggestion-icon { font-size: 28rpx; flex-shrink: 0; }
.suggestion-text { font-size: 24rpx; color: #333; line-height: 1.5; }
.record-list { margin-top: 8rpx; }
.record-item { display: flex; justify-content: space-between; align-items: center; padding: 16rpx 0; border-bottom: 1rpx solid #f3f4f6; }
.record-item:last-child { border-bottom: none; }
.record-left { display: flex; flex-direction: column; }
.record-time { font-size: 24rpx; color: #999; }
.record-val { font-size: 30rpx; font-weight: 600; color: #1a1a1a; margin-top: 4rpx; }
