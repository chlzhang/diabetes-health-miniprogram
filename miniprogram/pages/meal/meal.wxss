.meal-tabs{display:flex;justify-content:space-between;}
.meal-tab{display:flex;flex-direction:column;align-items:center;padding:16rpx 24rpx;border-radius:12rpx;background:#f5f5f5;flex:1;margin:0 6rpx;}
.meal-tab.active{background:#0d9488;color:#fff;}
.tab-icon{font-size:36rpx;margin-bottom:4rpx;}
.tab-name{font-size:22rpx;}
.form-group{margin-bottom:24rpx;}
.form-label{font-size:26rpx;font-weight:500;color:#333;margin-bottom:12rpx;display:block;}
.form-input{border:2rpx solid #e5e7eb;border-radius:12rpx;padding:16rpx 20rpx;font-size:28rpx;}
.form-textarea{border:2rpx solid #e5e7eb;border-radius:12rpx;padding:16rpx 20rpx;font-size:28rpx;width:100%;height:120rpx;box-sizing:border-box;}
.toggle-row{display:flex;gap:16rpx;margin-bottom:12rpx;}
.toggle-item{display:flex;align-items:center;gap:8rpx;padding:12rpx 24rpx;border:2rpx solid #e5e7eb;border-radius:12rpx;font-size:26rpx;}
.toggle-item.on{border-color:#0d9488;background:#f0fdfa;color:#0d9488;}
.toggle-check{font-weight:700;color:#0d9488;}
.meal-list{margin-top:8rpx;}
.meal-record{padding:12rpx 0;border-bottom:1rpx solid #f3f4f6;}
.meal-record:last-child{border-bottom:none;}
.meal-record-header{display:flex;justify-content:space-between;align-items:center;}
.meal-record-type{font-size:28rpx;font-weight:500;}
.meal-record-desc{font-size:24rpx;color:#666;margin-top:4rpx;display:block;}