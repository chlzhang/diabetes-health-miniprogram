.loading-state { text-align: center; padding: 120rpx 0; }
.loading-text { font-size: 28rpx; color: #999; }
.empty-state { text-align: center; padding: 80rpx 32rpx; background: #fff; border-radius: 16rpx; margin-top: 24rpx; }
.empty-icon { font-size: 96rpx; display: block; margin-bottom: 16rpx; }
.empty-title { font-size: 32rpx; font-weight: 600; color: #1a1a1a; display: block; margin-bottom: 8rpx; }
.empty-desc { font-size: 24rpx; color: #999; display: block; }

.hero-card { background: linear-gradient(135deg, #0d9488 0%, #14b8a6 100%); color: #fff; padding: 32rpx 24rpx; }
.hero-row { display: flex; align-items: center; }
.hero-item { flex: 1; text-align: center; }
.hero-num { font-size: 40rpx; font-weight: 700; display: block; }
.hero-label { font-size: 22rpx; opacity: 0.9; display: block; margin-top: 4rpx; }
.hero-divider { width: 2rpx; height: 70rpx; background: rgba(255,255,255,0.25); }
.hero-macro { display: flex; gap: 12rpx; justify-content: center; margin-top: 20rpx; flex-wrap: wrap; }
.macro-pill { padding: 8rpx 20rpx; border-radius: 20rpx; font-size: 22rpx; font-weight: 500; }
.macro-pill.protein { background: #fef3c7; color: #92400e; }
.macro-pill.carb { background: #dbeafe; color: #1e40af; }
.macro-pill.fat { background: #fed7aa; color: #9a3412; }

.tab-bar { display: flex; background: #fff; border-radius: 16rpx; padding: 8rpx; margin-bottom: 24rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); }
.tab { flex: 1; display: flex; flex-direction: column; align-items: center; padding: 16rpx; border-radius: 12rpx; }
.tab.on { background: #0d9488; color: #fff; }
.tab-icon { font-size: 32rpx; }
.tab-name { font-size: 24rpx; font-weight: 500; margin-top: 4rpx; }

.card-header { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 16rpx; }
.card-meta { font-size: 22rpx; color: #999; }

.meal-list { margin-top: 8rpx; }
.meal-card { background: #f9fafb; border-radius: 12rpx; padding: 20rpx; margin-bottom: 16rpx; }
.meal-card-head { display: flex; align-items: center; margin-bottom: 12rpx; }
.meal-icon { font-size: 32rpx; margin-right: 8rpx; }
.meal-name { font-size: 28rpx; font-weight: 600; color: #1a1a1a; flex: 1; }
.meal-kcal { font-size: 22rpx; color: #0d9488; font-weight: 500; }
.dish-list { }
.dish-row { display: flex; align-items: center; padding: 12rpx 0; border-top: 1rpx solid #e5e7eb; }
.dish-tag { width: 60rpx; font-size: 20rpx; color: #999; flex-shrink: 0; }
.dish-info { flex: 1; }
.dish-name { font-size: 26rpx; color: #1a1a1a; display: block; }
.dish-unit { font-size: 20rpx; color: #999; display: block; margin-top: 2rpx; }
.dish-macro { display: flex; flex-direction: column; gap: 2rpx; }
.macro-mini { font-size: 18rpx; color: #666; text-align: right; }

.focus-tag { display: inline-block; padding: 4rpx 16rpx; border-radius: 8rpx; font-size: 22rpx; font-weight: 500; margin: 4rpx 0 16rpx; }
.focus-cardio { background: #fee2e2; color: #dc2626; }
.focus-strength { background: #dbeafe; color: #1e40af; }
.focus-flexibility { background: #dcfce7; color: #16a34a; }
.focus-rest { background: #f3f4f6; color: #6b7280; }

.today-items { }
.today-item { display: flex; align-items: center; padding: 16rpx; background: #f9fafb; border-radius: 12rpx; margin-bottom: 12rpx; }
.today-icon { font-size: 40rpx; margin-right: 16rpx; }
.today-info { flex: 1; }
.today-name { font-size: 28rpx; font-weight: 500; color: #1a1a1a; display: block; }
.today-meta { font-size: 22rpx; color: #666; display: block; margin-top: 4rpx; }
.today-time { text-align: right; }
.time-num { font-size: 32rpx; font-weight: 700; color: #0d9488; display: block; }
.time-unit { font-size: 20rpx; color: #999; display: block; }
.today-empty { text-align: center; padding: 32rpx; color: #999; font-size: 26rpx; }
.today-foot { font-size: 24rpx; color: #0d9488; font-weight: 500; text-align: right; margin-top: 8rpx; }

.week-row { display: flex; justify-content: space-between; margin: 12rpx 0 16rpx; }
.day-cell { flex: 1; display: flex; flex-direction: column; align-items: center; padding: 12rpx 4rpx; border-radius: 8rpx; }
.day-cell.on { background: #f0fdfa; }
.day-name { font-size: 24rpx; color: #666; margin-bottom: 6rpx; }
.day-dot { width: 12rpx; height: 12rpx; border-radius: 50%; background: #e5e7eb; margin-bottom: 6rpx; }
.day-dot.focus-cardio { background: #dc2626; }
.day-dot.focus-strength { background: #1e40af; }
.day-dot.focus-flexibility { background: #16a34a; }
.day-dot.focus-rest { background: #9ca3af; }
.day-time { font-size: 20rpx; color: #999; }

.day-detail { background: #f9fafb; border-radius: 12rpx; padding: 20rpx; }
.day-detail-head { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 12rpx; }
.day-detail-title { font-size: 26rpx; font-weight: 600; color: #1a1a1a; }
.day-detail-time { font-size: 22rpx; color: #0d9488; font-weight: 500; }
.day-detail-item { display: flex; align-items: center; padding: 12rpx 0; border-top: 1rpx solid #e5e7eb; }
.d-icon { font-size: 32rpx; margin-right: 12rpx; }
.d-info { flex: 1; }
.d-name { font-size: 26rpx; color: #1a1a1a; display: block; }
.d-meta { font-size: 20rpx; color: #999; display: block; margin-top: 2rpx; }
.d-time { font-size: 24rpx; color: #0d9488; font-weight: 500; }

.quick-row { display: flex; gap: 16rpx; margin-top: 8rpx; }
.quick-btn { flex: 1; background: #fff; border-radius: 12rpx; padding: 20rpx; text-align: center; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); }
.quick-icon { font-size: 36rpx; display: block; }
.quick-label { font-size: 24rpx; color: #333; margin-top: 4rpx; display: block; }

@media (min-width: 768px) {
  .container { max-width: 720rpx; margin: 0 auto; padding: 32rpx 24rpx; }
  .meal-list { display: grid; grid-template-columns: 1fr 1fr; gap: 16rpx; }
  .meal-card { margin-bottom: 0; }
  .week-row { gap: 8rpx; }
}
