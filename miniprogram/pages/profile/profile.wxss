.hero-card { background: linear-gradient(135deg, #0d9488 0%, #14b8a6 100%); color: #fff; }
.hero-row { display: flex; align-items: center; }
.hero-item { flex: 1; text-align: center; }
.hero-num { font-size: 56rpx; font-weight: 700; display: block; }
.hero-empty { color: rgba(255,255,255,0.6); }
.hero-label { font-size: 22rpx; opacity: 0.85; display: block; margin-top: 4rpx; }
.hero-tag { display: inline-block; padding: 4rpx 14rpx; border-radius: 8rpx; font-size: 22rpx; margin-top: 8rpx; background: rgba(255,255,255,0.2); }
.hero-divider { width: 2rpx; height: 80rpx; background: rgba(255,255,255,0.25); }
.hero-tdee { font-size: 24rpx; opacity: 0.9; text-align: center; margin-top: 20rpx; }

.form-row { display: flex; gap: 16rpx; margin-bottom: 24rpx; }
.form-col { flex: 1; }
.form-group { margin-bottom: 24rpx; }
.form-label { font-size: 26rpx; font-weight: 500; color: #333; margin-bottom: 12rpx; display: block; }
.form-input { border: 2rpx solid #e5e7eb; border-radius: 12rpx; padding: 16rpx 20rpx; font-size: 28rpx; width: 100%; box-sizing: border-box; }

.chip-row { display: flex; gap: 12rpx; }
.chip-row.wrap { flex-wrap: wrap; }
.chip { padding: 12rpx 28rpx; border: 2rpx solid #e5e7eb; border-radius: 32rpx; font-size: 26rpx; }
.chip.on { background: #0d9488; color: #fff; border-color: #0d9488; }

.hint-text { font-size: 22rpx; color: #999; margin-top: 8rpx; display: block; }

.goal-list { margin-top: 8rpx; }
.goal-item { display: flex; align-items: center; padding: 20rpx; border: 2rpx solid #e5e7eb; border-radius: 12rpx; margin-bottom: 12rpx; }
.goal-item.on { border-color: #0d9488; background: #f0fdfa; }
.goal-icon { font-size: 40rpx; margin-right: 16rpx; }
.goal-info { flex: 1; }
.goal-name { font-size: 28rpx; font-weight: 600; color: #1a1a1a; display: block; }
.goal-desc { font-size: 22rpx; color: #666; display: block; margin-top: 4rpx; }
.goal-check { width: 40rpx; height: 40rpx; border-radius: 50%; background: #0d9488; color: #fff; display: flex; align-items: center; justify-content: center; font-size: 24rpx; font-weight: 700; }

.macro-grid { display: flex; gap: 16rpx; margin-top: 8rpx; }
.macro-item { flex: 1; padding: 24rpx 12rpx; border-radius: 12rpx; text-align: center; }
.macro-item.protein { background: #fef3c7; }
.macro-item.carb { background: #dbeafe; }
.macro-item.fat { background: #fed7aa; }
.macro-num { font-size: 40rpx; font-weight: 700; color: #1a1a1a; display: block; }
.macro-label { font-size: 22rpx; color: #666; display: block; margin-top: 4rpx; }

.bottom-hint { text-align: center; font-size: 22rpx; color: #999; margin-top: 16rpx; }

/* 桌面端适配 */
@media (min-width: 768px) {
  .container { max-width: 720rpx; margin: 0 auto; padding: 32rpx 24rpx; }
  .form-row { gap: 24rpx; }
  .macro-grid { gap: 24rpx; }
}
