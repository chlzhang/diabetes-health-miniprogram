.profile-card { display: flex; flex-direction: column; align-items: center; padding: 40rpx 24rpx; }
.avatar-wrap { margin-bottom: 16rpx; }
.avatar { width: 120rpx; height: 120rpx; border-radius: 50%; }
.avatar-placeholder { width: 120rpx; height: 120rpx; border-radius: 50%; background: #0d9488; display: flex; align-items: center; justify-content: center; }
.avatar-text { font-size: 48rpx; color: #fff; font-weight: 600; }
.user-name { font-size: 32rpx; font-weight: 600; color: #1a1a1a; }
.stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16rpx; margin-bottom: 24rpx; }
.stat-card { background: #fff; border-radius: 16rpx; padding: 24rpx 12rpx; text-align: center; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); }
.stat-number { font-size: 40rpx; font-weight: 700; color: #0d9488; display: block; }
.stat-label { font-size: 20rpx; color: #999; display: block; margin-top: 4rpx; }
.menu-card { padding: 0; }
.menu-section-title { font-size: 24rpx; color: #999; padding: 16rpx 24rpx 0; }
.menu-item { display: flex; align-items: center; padding: 28rpx 24rpx; border-bottom: 1rpx solid #f3f4f6; }
.menu-item:last-child { border-bottom: none; }
.menu-icon { font-size: 36rpx; margin-right: 16rpx; }
.menu-text { flex: 1; font-size: 28rpx; color: #333; }
.menu-arrow { font-size: 24rpx; color: #999; }
.footer { text-align: center; padding: 40rpx 0; }
.footer-text { font-size: 22rpx; color: #ccc; }
