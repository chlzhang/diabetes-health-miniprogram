<view class="container">
  <view class="profile-card card">
    <view class="avatar-wrap">
      <image class="avatar" wx:if="{{userInfo.avatarUrl}}" src="{{userInfo.avatarUrl}}" mode="aspectFill"/>
      <view class="avatar-placeholder" wx:else>
        <text class="avatar-text">{{userInfo.nickName[0] || '?'}}</text>
      </view>
    </view>
    <text class="user-name">{{userInfo.nickName || '用户'}}</text>
  </view>

  <view class="stats-grid">
    <view class="stat-card">
      <text class="stat-number">{{stats.streakDays}}</text>
      <text class="stat-label">连续打卡</text>
    </view>
    <view class="stat-card">
      <text class="stat-number">{{stats.totalMeals}}</text>
      <text class="stat-label">饮食记录</text>
    </view>
    <view class="stat-card">
      <text class="stat-number">{{stats.totalExercises}}</text>
      <text class="stat-label">运动次数</text>
    </view>
    <view class="stat-card">
      <text class="stat-number">{{stats.totalBSChecks}}</text>
      <text class="stat-label">血糖测量</text>
    </view>
  </view>

  <view class="card menu-card">
    <view class="menu-section-title">个性化</view>
    <view class="menu-item" bindtap="goProfile">
      <text class="menu-icon">📊</text>
      <text class="menu-text">身体数据</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goPlan">
      <text class="menu-icon">📋</text>
      <text class="menu-text">我的方案</text>
      <text class="menu-arrow">饮食 · 运动 ›</text>
    </view>
    <view class="menu-item" bindtap="goTracking">
      <text class="menu-icon">📈</text>
      <text class="menu-text">打卡追踪</text>
      <text class="menu-arrow">依从率 ›</text>
    </view>
    <view class="menu-item" bindtap="goAIChat">
      <text class="menu-icon">💬</text>
      <text class="menu-text">AI 健康助手</text>
      <text class="menu-arrow">大模型驱动 ›</text>
    </view>
    <view class="menu-item" bindtap="goPreferences">
      <text class="menu-icon">⚙️</text>
      <text class="menu-text">偏好设置</text>
      <text class="menu-arrow">饮食禁忌 · 运动限制 ›</text>
    </view>
  </view>

  <view class="card menu-card">
    <view class="menu-section-title">其他</view>
    <view class="menu-item" bindtap="goFamily">
      <text class="menu-icon">👨‍👩‍👧‍👦</text>
      <text class="menu-text">家庭管理</text>
      <text class="menu-arrow" wx:if="{{hasFamily}}">{{memberCount}}人 ›</text>
      <text class="menu-arrow" wx:else>未加入 ›</text>
    </view>
    <view class="menu-item" wx:if="{{hasFamily}}" bindtap="copyCode">
      <text class="menu-icon">📋</text>
      <text class="menu-text">复制家庭码</text>
      <text class="menu-arrow">{{familyCode}}</text>
    </view>
    <view class="menu-item" bindtap="clearCache">
      <text class="menu-icon">🧹</text>
      <text class="menu-text">清除缓存</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="footer">
    <text class="footer-text">糖前期生活监督 v1.0.0</text>
  </view>
</view>
