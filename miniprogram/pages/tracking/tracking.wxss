.loading-state { text-align: center; padding: 120rpx 0; }
.loading-text { font-size: 28rpx; color: #999; }

.hero-card { background: linear-gradient(135deg, #0d9488 0%, #14b8a6 100%); color: #fff; }
.hero-row { display: flex; align-items: center; }
.hero-item { flex: 1; text-align: center; }
.hero-num { font-size: 44rpx; font-weight: 700; display: block; }
.hero-label { font-size: 22rpx; opacity: 0.9; display: block; margin-top: 4rpx; }
.hero-divider { width: 2rpx; height: 70rpx; background: rgba(255,255,255,0.25); }

.range-bar { display: flex; background: #fff; border-radius: 12rpx; padding: 6rpx; margin-bottom: 24rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); }
.range-btn { flex: 1; text-align: center; padding: 14rpx; font-size: 26rpx; color: #666; border-radius: 8rpx; }
.range-btn.on { background: #0d9488; color: #fff; }

.hint-text { font-size: 22rpx; color: #999; display: block; margin-bottom: 16rpx; }

.week-grid { display: flex; gap: 8rpx; overflow-x: auto; padding-bottom: 4rpx; }
.day-cell { flex: 0 0 96rpx; display: flex; flex-direction: column; align-items: center; padding: 12rpx 4rpx; background: #f9fafb; border-radius: 8rpx; }
.day-label { font-size: 22rpx; color: #666; margin-bottom: 8rpx; }
.day-bars { display: flex; gap: 4rpx; margin-bottom: 6rpx; }
.bar { width: 12rpx; height: 24rpx; border-radius: 2rpx; background: #e5e7eb; }
.bar.diet-bar.on { background: #16a34a; }
.bar.ex-bar.on { background: #0d9488; }
.day-meta { font-size: 18rpx; color: #999; }

.stat-row { display: flex; gap: 16rpx; margin-top: 8rpx; }
.stat-block { flex: 1; background: #f9fafb; border-radius: 12rpx; padding: 20rpx; text-align: center; }
.stat-num { font-size: 40rpx; font-weight: 700; color: #0d9488; display: block; }
.stat-label { font-size: 22rpx; color: #666; display: block; margin-top: 4rpx; }
.stat-target { font-size: 20rpx; color: #999; display: block; margin-top: 4rpx; }

.recent-item { display: flex; align-items: center; justify-content: space-between; padding: 16rpx 0; border-bottom: 1rpx solid #f3f4f6; }
.recent-item:last-child { border-bottom: none; }
.recent-left { flex: 1; }
.recent-type { font-size: 28rpx; font-weight: 500; color: #1a1a1a; display: block; }
.recent-date { font-size: 22rpx; color: #999; display: block; margin-top: 4rpx; }
.recent-kcal { font-size: 24rpx; color: #0d9488; font-weight: 500; }
.empty-mini { text-align: center; padding: 24rpx; color: #999; font-size: 24rpx; }

.quick-row { display: flex; gap: 16rpx; margin-top: 8rpx; }
.quick-btn { flex: 1; background: #fff; border-radius: 12rpx; padding: 20rpx; text-align: center; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); }
.quick-icon { font-size: 36rpx; display: block; }
.quick-label { font-size: 24rpx; color: #333; margin-top: 4rpx; display: block; }

@media (min-width: 768px) {
  .container { max-width: 720rpx; margin: 0 auto; padding: 32rpx 24rpx; }
  .week-grid { overflow-x: visible; justify-content: space-between; }
  .stat-row { gap: 24rpx; }
}
