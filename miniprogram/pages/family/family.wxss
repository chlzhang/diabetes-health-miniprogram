.empty-state { text-align: center; padding: 80rpx 0 40rpx; }
.empty-icon { font-size: 96rpx; display: block; margin-bottom: 16rpx; }
.empty-title { font-size: 32rpx; font-weight: 600; color: #1a1a1a; display: block; margin-bottom: 8rpx; }
.empty-desc { font-size: 26rpx; color: #999; display: block; }
.action-buttons { display: flex; gap: 24rpx; margin-bottom: 32rpx; }
.action-buttons button { flex: 1; }
.btn-secondary { background: #fff; color: #0d9488; border: 2rpx solid #0d9488; border-radius: 12rpx; padding: 20rpx 40rpx; font-size: 30rpx; text-align: center; }
.btn-ghost { background: transparent; color: #999; border: none; padding: 20rpx 40rpx; font-size: 28rpx; }
.btn-row { display: flex; gap: 16rpx; }
.btn-sm { font-size: 26rpx; padding: 16rpx 32rpx; }
.form-group { margin-bottom: 24rpx; }
.form-input { border: 2rpx solid #e5e7eb; border-radius: 12rpx; padding: 16rpx 20rpx; font-size: 28rpx; }
.family-header { text-align: center; }
.family-title { font-size: 36rpx; font-weight: 700; color: #1a1a1a; display: block; margin-bottom: 16rpx; }
.code-row { display: flex; align-items: center; justify-content: center; background: #f5f5f5; padding: 12rpx 24rpx; border-radius: 12rpx; }
.code-label { font-size: 24rpx; color: #999; }
.code-value { font-size: 32rpx; font-weight: 700; color: #0d9488; letter-spacing: 4rpx; }
.code-copy { font-size: 22rpx; color: #0d9488; margin-left: 16rpx; text-decoration: underline; }
.member-list { margin-top: 8rpx; }
.member-item { display: flex; align-items: center; padding: 16rpx 0; border-bottom: 1rpx solid #f3f4f6; }
.member-item:last-child { border-bottom: none; }
.member-avatar { width: 72rpx; height: 72rpx; border-radius: 50%; background: #0d9488; color: #fff; display: flex; align-items: center; justify-content: center; font-size: 30rpx; font-weight: 600; margin-right: 20rpx; flex-shrink: 0; }
.member-info { flex: 1; }
.member-name { font-size: 28rpx; font-weight: 500; color: #1a1a1a; display: block; }
.member-stats { display: flex; gap: 24rpx; margin-top: 6rpx; }
.stat-item { font-size: 22rpx; color: #666; }
.share-hint { font-size: 24rpx; color: #999; display: block; margin-bottom: 16rpx; }
.loading-state { text-align: center; padding: 120rpx 0; }
.loading-text { font-size: 28rpx; color: #999; }
